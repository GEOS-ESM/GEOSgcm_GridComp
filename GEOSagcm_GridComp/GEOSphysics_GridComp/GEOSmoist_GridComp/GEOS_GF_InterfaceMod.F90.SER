         !$ser flush_savepoint GF2020_CumulusParameterization_AtmosphericComposition-Out
         !$ser flush_savepoint GF2020_CumulusParameterization_LargeScaleForcing-In
         !$ser flush_savepoint GF2020_CumulusParameterization_LargeScaleForcing-Out
    ELSE
         !- call GF/GEOS5 interface routine
         ! PLE and PL are passed in Pa
         call GF_GEOS5_Interface( IM,JM,LM,LONS,LATS,GF_DT                       &
                                 ,PLE, PL, ZLE0, ZL0, PK, MASS, OMEGA               &
                                 ,T, TH, Q, U, V, QLCN, QICN, QLLS, QILS, CNPCPRATE &
                                 ,CNV_MF0, CNV_PRC3, MFD_DC, CNV_DQCDT,ENTLAM       &
                                 ,UMF_DC, CNV_UPDF, CNV_CVW, CNV_QC , CLCN          &
                                 ,QV_DYN_IN,PLE_DYN_IN,U_DYN_IN,V_DYN_IN,T_DYN_IN   &
                                 ,RADSW   ,RADLW  ,DQDT_BL  ,DTDT_BL                &
                                 ,FRLAND, TMP2D, T2M, Q2M      &
                                 ,TA ,QA ,SH ,EVAP ,PHIS                            &
                                 ,KPBL ,CNV_FRC, SRF_TYPE                           &
                                 ,SEEDCNV, SIGMA_DEEP, SIGMA_MID                    &
                                 ,DQVDT_DC,DTDT_DC,DUDT_DC,DVDT_DC                  &
                                 ,MUPDP,MUPSH,MUPMD                                 &
                                 ,MFDP,MFSH,MFMD,ERRDP,ERRSH,ERRMD                  &
                                 ,AA0,AA1,AA2,AA3,AA1_BL,AA1_CIN,TAU_BL,TAU_EC      &
                                 ,DTDTDYN,DQVDTDYN                                  &
                                 ,REVSU, PRFIL)
    ENDIF

    ! NOTE this savepoint is also used as GF2020_Finalize-Out
    !$ser savepoint GF2020-Out
    ! add tendencies to the moist import state
      U  = U  +  DUDT_DC*GF_DT
      V  = V  +  DVDT_DC*GF_DT
      Q  = Q  + DQVDT_DC*GF_DT
      T  = T  +  DTDT_DC*GF_DT
      TH = T/PK
    ! update DeepCu QL/QI/CF tendencies
      fQi = ice_fraction( T, CNV_FRC, SRF_TYPE )
      TMP3D    = CNV_DQCDT/MASS
      DQLDT_DC = (1.0-fQi)*TMP3D
      DQIDT_DC =      fQi *TMP3D
      DQADT_DC = MFD_DC*SCLM_DEEP/MASS
    ! evap/subl and precip fluxes
      do L=1,LM
         !--- sublimation/evaporation tendencies (kg/kg/s)
           RSU_CN (:,:,L) = REVSU(:,:,L)*     fQi(:,:,L)
           REV_CN (:,:,L) = REVSU(:,:,L)*(1.0-fQi(:,:,L))
         !--- preciptation fluxes (kg/kg/s)
           PFI_CN (:,:,L) = PRFIL(:,:,L)*     fQi(:,:,L)
           PFL_CN (:,:,L) = PRFIL(:,:,L)*(1.0-fQi(:,:,L))
      enddo
    ! add QI/QL/CL tendencies
      QLCN =         QLCN + DQLDT_DC*GF_DT
      QICN =         QICN + DQIDT_DC*GF_DT
      CLCN = MAX(MIN(CLCN + DQADT_DC*GF_DT, 1.0), 0.0)
    ! Export
      call MAPL_GetPointer(EXPORT, PTR3D, 'CNV_FICE', RC=STATUS); VERIFY_(STATUS)
      if (associated(PTR3D)) PTR3D = fQi
      !$ser verbatim if (associated(PTR3D)) then
         !$ser data ice_fraction_in_convective_tower_bugworkaroundname=PTR3D
      !$ser verbatim endif
    ! fix 'convective' cloud fraction
      if (FIX_CNV_CLOUD) then
      ! fix convective cloud
      TMP3D = GEOS_DQSAT(T, PL, PASCALS=.true., QSAT=QST3)
      TMP3D = QST3
      WHERE (CLCN < 1.0)
         TMP3D = ( Q - QST3 * CLCN )/(1.-CLCN)
      END WHERE
      minrhx = 0.001
      WHERE ( (( TMP3D - minrhx*QST3 ) < 0.0 ) .AND. (CLCN > 0.0) )
         CLCN = (Q  - minrhx*QST3 )/( QST3*(1.0-minrhx) )
      END WHERE
      ! If still cant make suitable env RH then destroy anvil
      WHERE ( CLCN < 0.0 )
         CLCN = 0.
         DQLDT_DC = DQLDT_DC - (QLCN       )/GF_DT
         DQIDT_DC = DQIDT_DC - (       QICN)/GF_DT
         DQVDT_DC = DQVDT_DC + (QLCN + QICN)/GF_DT
          Q       =  Q       + (QLCN + QICN)
         TMP3D    = (MAPL_ALHL*QLCN + MAPL_ALHS*QICN)/MAPL_CP
         DTDT_DC  = DTDT_DC  - TMP3D/GF_DT
          T       =  T       - TMP3D
          TH      =  T/PK
         QLCN = 0.
         QICN = 0.
      END WHERE
      endif

      !--------------------------------------------------------------
      !  For Now add DeepCu contribution to total/detraining mass flux exports
      !--------------------------------------------------------------
       call MAPL_GetPointer(EXPORT, PTR3D, 'CNV_MFC', ALLOC=.TRUE., RC=STATUS); VERIFY_(STATUS)
       PTR3D = PTR3D + UMF_DC
       !$ser verbatim if (associated(PTR3D)) then
         !$ser data total_cumulative_mass_flux_interface_bugworkaroundname=PTR3D
       !$ser verbatim endif
       call MAPL_GetPointer(EXPORT, PTR3D, 'CNV_MFD', ALLOC=.TRUE., RC=STATUS); VERIFY_(STATUS)
       PTR3D = PTR3D + MFD_DC
       !$ser verbatim if (associated(PTR3D)) then
         !$ser data total_detraining_mass_flux_bugworkaroundname=PTR3D
       !$ser verbatim endif

      call MAPL_GetPointer(EXPORT, PTR3D, 'DQRC', RC=STATUS); VERIFY_(STATUS)
       !$ser verbatim if (associated(PTR3D)) then
         !$ser data convective_rainwater_source_bugworkaroundname=PTR3D
       !$ser verbatim endif
      if(associated(PTR3D)) PTR3D = CNV_PRC3 / GF_DT

    ! NOTE this savepoint is also used as GF2020_Finalize-Out
    ! savepoint is defined above this block (after calls to cumulus parameterization schemes)
    ! so that the temporary export field PTR3D can be serialized numerous times
    !$ser data latitude_bugworkaroundname=LATS
    !$ser data longitude_bugworkaroundname=LONS
    !$ser data p_interface_bugworkaroundname=PLE
    !$ser data t_bugworkaroundname=T
    !$ser data u_bugworkaroundname=U
    !$ser data v_bugworkaroundname=V
    !$ser data w_bugworkaroundname=W
    !$ser data omega_bugworkaroundname=OMEGA
    !$ser data t_2m_bugworkaroundname=T2M
    !$ser data specific_humidity_2m_bugworkaroundname=Q2M
    !$ser data t_surface_bugworkaroundname=TA
    !$ser data specific_humidity_surface_bugworkaroundname=QA
    !$ser data vapor_bugworkaroundname=Q
    !$ser data convective_liquid_bugworkaroundname=QLCN
    !$ser data convective_ice_bugworkaroundname=QICN
    !$ser data convective_cloud_fraction_bugworkaroundname=CLCN
    !$ser data large_scale_liquid_bugworkaroundname=QLLS
    !$ser data large_scale_ice_bugworkaroundname=QILS
    !$ser data large_scale_cloud_fraction_bugworkaroundname=CLLS
    !$ser data p_interface_timestep_start_bugworkaroundname=PLE_DYN_IN
    !$ser data t_timestep_start_bugworkaroundname=T_DYN_IN
    !$ser data u_timestep_start_bugworkaroundname=U_DYN_IN
    !$ser data v_timestep_start_bugworkaroundname=V_DYN_IN
    !$ser data vapor_timestep_start_bugworkaroundname=QV_DYN_IN
    !$ser data geopotential_height_interface_bugworkaroundname=ZLE
    !$ser data geopotential_height_surface_bugworkaroundname=PHIS
    !$ser data area_bugworkaroundname=AREA
    !$ser data pbl_level_bugworkaroundname=KPBL
    !$ser data convection_fraction_bugworkaroundname=CNV_FRC
    !$ser data surface_type_bugworkaroundname=SRF_TYPE
    !$ser data seed_convection_bugworkaroundname=SEEDCNV
    !$ser data land_fraction_bugworkaroundname=FRLAND
    !$ser data scalar_diffusivity_bugworkaroundname=KH
    !$ser data buoyancy_bugworkaroundname=BYNCY
    !$ser data convective_precipitation_GF_bugworkaroundname=CNPCPRATE
    !$ser data convective_precipitation_RAS_bugworkaroundname=CNV_PRC3
    !$ser data sensible_heat_flux_bugworkaroundname=SH
    !$ser data total_water_flux_deep_convection_interface_bugworkaroundname=WQT_DC
    !$ser data evaporation_bugworkaroundname=EVAP
    !$ser data sublimation_of_convective_precipitation_bugworkaroundname=RSU_CN
    !$ser data evaporation_of_convective_precipitation_bugworkaroundname=REV_CN
    !$ser data ice_precip_flux_interface_bugworkaroundname=PFI_CN
    !$ser data liquid_precip_flux_interface_bugworkaroundname=PFL_CN
    !$ser data convective_condensate_source_bugworkaroundname=CNV_DQCDT
    !$ser data convective_condensate_grid_mean_bugworkaroundname=CNV_QC
    !$ser data entrainment_parameter_bugworkaroundname=ENTLAM
    !$ser data lateral_entrainment_rate_bugworkaroundname=ENTR
    !$ser data lateral_entrainment_rate_shallow_bugworkaroundname=ENTR_SH
    !$ser data lateral_entrainment_rate_mid_bugworkaroundname=ENTR_MD
    !$ser data lateral_entrainment_rate_deep_bugworkaroundname=ENTR_DP
    !$ser data updraft_areal_fraction_bugworkaroundname=CNV_UPDF
    !$ser data updraft_vertical_velocity_bugworkaroundname=CNV_CVW
    !$ser data dtdt_shortwave_bugworkaroundname=RADSW
    !$ser data dtdt_longwave_bugworkaroundname=RADLW
    !$ser data dspecific_humiditydt_pbl_bugworkaroundname=DQDT_BL
    !$ser data dtdt_pbl_bugworkaroundname=DTDT_BL
    !$ser data dtdt_from_dynamics_bugworkaroundname=DTDTDYN
    !$ser data dvapordt_from_dynamics_bugworkaroundname=DQVDTDYN
    !$ser data sigma_mid_bugworkaroundname=SIGMA_MID
    !$ser data sigma_deep_bugworkaroundname=SIGMA_DEEP
    !$ser data total_precipitable_water_initial_bugworkaroundname=TPWI
    !$ser data saturation_total_precipitable_water_initial_bugworkaroundname=TPWI_star
    !$ser data dvapordt_deep_convection_bugworkaroundname=DQVDT_DC
    !$ser data dtdt_deep_convection_bugworkaroundname=DTDT_DC
    !$ser data dudt_deep_convection_bugworkaroundname=DUDT_DC
    !$ser data dvdt_deep_convection_bugworkaroundname=DVDT_DC
    !$ser data dliquiddt_deep_convection_bugworkaroundname=DQLDT_DC
    !$ser data dicedt_deep_convection_bugworkaroundname=DQIDT_DC
    !$ser data dcloudfractiondt_deep_convection_bugworkaroundname=DQADT_DC
    !$ser data pressure_shallow_convective_cloud_top_bugworkaroundname=CNV_TOPP_SH
    !$ser data pressure_mid_convective_cloud_top_bugworkaroundname=CNV_TOPP_MD
    !$ser data pressure_deep_convective_cloud_top_bugworkaroundname=CNV_TOPP_DP
    !$ser data mass_flux_shallow_bugworkaroundname=MUPSH
    !$ser data mass_flux_mid_bugworkaroundname=MUPMD
    !$ser data mass_flux_deep_updraft_bugworkaroundname=MUPDP
    !$ser data mass_flux_deep_updraft_interface_bugworkaroundname=UMF_DC
    !$ser data mass_flux_deep_updraft_detrained_bugworkaroundname=MFD_DC
    !$ser data mass_flux_deep_downdraft_bugworkaroundname=MDNDP
    !$ser data mass_flux_cloud_base_bugworkaroundname=CNV_MF0
    !$ser data mass_flux_cloud_base_shallow_bugworkaroundname=MFSH
    !$ser data mass_flux_cloud_base_mid_bugworkaroundname=MFMD
    !$ser data mass_flux_cloud_base_deep_bugworkaroundname=MFDP
    !$ser data convection_code_shallow_bugworkaroundname=ERRSH
    !$ser data convection_code_mid_bugworkaroundname=ERRMD
    !$ser data convection_code_deep_bugworkaroundname=ERRDP
    !$ser data cloud_workfunction_0_bugworkaroundname=AA0
    !$ser data cloud_workfunction_1_bugworkaroundname=AA1
    !$ser data cloud_workfunction_2_bugworkaroundname=AA2
    !$ser data cloud_workfunction_3_bugworkaroundname=AA3
    !$ser data cloud_workfunction_1_pbl_bugworkaroundname=AA1_BL
    !$ser data cloud_workfunction_1_cin_bugworkaroundname=AA1_CIN
    !$ser data pbl_time_scale_bugworkaroundname=TAU_BL
    !$ser data cape_removal_time_scale_bugworkaroundname=TAU_EC
    !$ser data lightning_density_bugworkaroundname=LFR_GF
    !$ser data convection_tracer_bugworkaroundname=CNV_TR
    call MAPL_TimerOff (MAPL,"--GF")

    endif

end subroutine GF_Run

end module GEOS_GF_InterfaceMod
